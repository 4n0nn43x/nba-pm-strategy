# The Odds API — free key at https://the-odds-api.com/
THE_ODDS_API_KEY=your_key_here

# OpenRouter — free key at https://openrouter.ai/
# Used for AI signal confidence scoring (optional — scanner runs without it)
OPENROUTER_API_KEY=
# Model to use for AI scoring — any model available on openrouter.ai/models
# Default: google/gemini-2.5-pro ($1.25/M input, $10/M output — best value paid model)
# Alternatives:
#   anthropic/claude-sonnet-4.6   — $3/$15 per M tokens
#   meta-llama/llama-3.3-70b-instruct:free — free tier (less reliable)
OPENROUTER_MODEL=google/gemini-2.5-pro

# Optional: override poll interval (ms)
POLL_INTERVAL_MS=30000
